# ---------------------------------------------------------------------------
# Local development environment template.
#
# Copy this file to `.env` (which is gitignored) and fill in real values:
#     cp .env.example .env
#
# Anything in `.env` is loaded automatically when you run `pnpm dev`.
# ---------------------------------------------------------------------------

# Any long random string. Used to sign session cookies. Generate one with:
#     node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-me-with-a-long-random-string

# Your OpenAI API key — required for the BI Companion chat (CopilotKit runtime).
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional: model for the BI Companion chat. Default gpt-4.1-mini.
# OPENAI_MODEL=gpt-4.1-mini

# Optional: log verbosity for the API server. One of: trace|debug|info|warn|error
LOG_LEVEL=info

# Optional: where the Vite dev server should proxy /api/* to. Only override
# if your API server runs on a non-default port or host.
# API_PROXY_TARGET=http://localhost:8080

# Postgres for pinned visuals. The API server stores pinned charts (+ their
# queries) in a dedicated database named `loki`, created automatically on first
# use. Point this at your local Postgres; the `loki` DB will be created for you.
LOKI_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/loki

# ---------------------------------------------------------------------------
# Python Loki service (services/agents-py) — FastAPI proxy to the Loki server.
# ---------------------------------------------------------------------------

# When set, Express PROXIES /api/loki/* to the Python service. Required for the
# Loki Logs tab.
AGENTS_SERVICE_URL=http://localhost:8000

# The Loki server to read logs from.
LOKI_URL=http://65.0.120.127:3100

# Optional Loki tuning.
# LOKI_TIMEOUT=30
# LOKI_LABEL_WINDOW=30d

# The dashboard's geographic threat map geolocates attacker IPs via a best-effort
# server-side call to ip-api.com (free, no key, rate-limited). No config needed;
# if egress is blocked the map simply shows no plotted points.
