# ---------------------------------------------------------------------------
# Local development environment template.
#
# Copy this file to `.env` (which is gitignored) and fill in real values:
#     cp .env.example .env
#
# Anything in `.env` is loaded automatically when you run `pnpm dev`.
# ---------------------------------------------------------------------------

# Postgres connection string. Create the database on your machine first, e.g.
#     createdb genbi
# then point this at it. SSL is not required for local Postgres.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/genbi

# Any long random string. Used to sign session cookies. Generate one with:
#     node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-me-with-a-long-random-string

# Your OpenAI API key — required for the Gen-BI Copilot (chat + dashboard
# generation). Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional: log verbosity for the API server. One of: trace|debug|info|warn|error
LOG_LEVEL=info

# Optional: which tenant config to load on boot. Default is `insurance-broker`.
# TENANT=insurance-broker

# Optional: where the Vite dev server should proxy /api/* to. Only override
# if your API server runs on a non-default port or host.
# API_PROXY_TARGET=http://localhost:8080
