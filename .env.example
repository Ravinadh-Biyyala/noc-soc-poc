# ---------------------------------------------------------------------------
# Local development environment template.
#
# Copy this file to `.env` (which is gitignored) and fill in real values:
#     cp .env.example .env
#
# Anything in `.env` is loaded automatically when you run `pnpm dev`.
# ---------------------------------------------------------------------------

# Postgres connection string. Create the database on your machine first, e.g.
#     createdb genbi
# then point this at it. SSL is not required for local Postgres.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/genbi

# Any long random string. Used to sign session cookies. Generate one with:
#     node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-me-with-a-long-random-string

# Your OpenAI API key — required for the Gen-BI Copilot (chat + dashboard
# generation). Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional: log verbosity for the API server. One of: trace|debug|info|warn|error
LOG_LEVEL=info

# Optional: which tenant config to load on boot. Default is `insurance-broker`.
# TENANT=insurance-broker

# Optional: where the Vite dev server should proxy /api/* to. Only override
# if your API server runs on a non-default port or host.
# API_PROXY_TARGET=http://localhost:8080

# ---------------------------------------------------------------------------
# Python agent service (services/agents-py) — LangChain + LangGraph.
# ---------------------------------------------------------------------------

# When set, Express PROXIES the AI agent vertical (data-engineer / data-modeler /
# metric-architect suggest + accept/reject, semantic-model, metrics, dashboards,
# warehouse-tables, relationships, analyst-chat SSE, pipeline) to the Python
# service. Leave UNSET to keep serving those routes from the TS routers.
# AGENTS_SERVICE_URL=http://localhost:8000

# The Python service reuses DATABASE_URL above and the OpenAI integration vars
# below (already provisioned in this environment). It models against gpt-4.1-mini
# by default.
# AI_INTEGRATIONS_OPENAI_API_KEY=sk-...
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_MAX_TOKENS=4096

# LangSmith tracing for the Python agents. The service overrides the project to
# `genbi-agents` via services/agents-py/.env so its traces stay separate from
# the Node copilot's project.
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=ls-...
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_PROJECT=genbi-agents
