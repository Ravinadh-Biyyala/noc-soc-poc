# ---------------------------------------------------------------------------
# Python agent service — local config template.
#
# By default the service reads the repo-root `.env` (shared with Express). This
# file is only needed to OVERRIDE values for the Python service, e.g. to point
# tracing at a dedicated LangSmith project or to change the port.
#
# Copy to `.env` in this directory and fill in only what you want to override.
# ---------------------------------------------------------------------------

# Tracing project for the migrated agents (kept separate from the Node copilot).
LANGSMITH_PROJECT=genbi-agents

# Port this service listens on (Express proxies here when AGENTS_SERVICE_URL is set).
AGENTS_PORT=8000

# Frontend origin allowed by CORS (when hit directly rather than via Express).
CORS_ORIGIN=http://localhost:5173

# --- The following are normally inherited from the repo-root .env ---
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/genbi
# AI_INTEGRATIONS_OPENAI_API_KEY=sk-...
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_MAX_TOKENS=4096
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=ls-...
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
